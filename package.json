{
  "name": "next-version",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Next version GitHub Action using conventional commits",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs --sourcemap",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "all": "npm run typecheck && npm run format && npm run lint && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conventional-actions/next-version.git"
  },
  "homepage": "https://github.com/conventional-actions/next-version",
  "bugs": {
    "url": "https://github.com/conventional-actions/next-version/issues"
  },
  "keywords": [
    "GitHub",
    "action",
    "version",
    "versions",
    "generation",
    "generate",
    "bump",
    "prepare"
  ],
  "author": "Conventional Actions",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "concat-stream": "^2.0.0",
    "conventional-commits-filter": "^2.0.7",
    "conventional-commits-parser": "^3.2.4",
    "git-raw-commits": "^2.0.11",
    "git-semver-tags": "^4.1.1",
    "semver": "^7.3.8"
  },
  "devDependencies": {
    "@types/concat-stream": "^2.0.0",
    "@types/conventional-commits-parser": "^3.0.3",
    "@types/git-raw-commits": "^2.0.1",
    "@types/git-semver-tags": "^4.1.1",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.3.13",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "eslint-plugin-github": "^5.1.8",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.0"
  }
}
